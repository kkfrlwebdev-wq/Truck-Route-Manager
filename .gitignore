# ---------------------------------------------------------------------
*.log
npm-debug.log*
.pytest_cache/
.eslintcache

# ---------------------------------------------------------------------
# IDE & Editor Settings (Personal workspace configurations)
# ---------------------------------------------------------------------
.vscode/
.idea/
*.suo
*.ntvs*
*.sln
*.sw?

*.tsbuildinfo
